# Konfigurasi Laravel API
LARAVEL_API_URL=http://localhost:8000

# Shared secret buat akses endpoint /internal/* di Laravel -- harus sama
# persis dengan INTERNAL_SERVICE_KEY di api-blue/.env
INTERNAL_SERVICE_KEY=

# Konfigurasi CORS (comma-separated, tanpa spasi)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Content-based similarity
CBF_TOP_K=8

# Cache produk (menit) -- refresh berkala dari Laravel API
PRODUCT_CACHE_REFRESH_MINUTES=30

# Collaborative filtering (SVD)
CF_TOP_K=8
CF_MIN_INTERACTIONS=50
CF_MIN_ACTIVE_USERS=5
CF_RETRAIN_INTERVAL_HOURS=24
CF_MODEL_PATH=/app/models/svd_model.pkl
